---
interface BreadcrumbItem {
    name: string;
    url: string;
}

interface Props {
    title: string;
    description: string;
    canonical: string;
    robots?: string;
    breadcrumbs?: BreadcrumbItem[];
}

const { title, description, canonical, robots = "index, follow", breadcrumbs } = Astro.props;
const siteName = "ST BERATUNG";

// Generate BreadcrumbList JSON-LD if breadcrumbs provided
const breadcrumbSchema = breadcrumbs ? JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((item, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": item.name,
        "item": item.url
    }))
}) : null;

import "../styles/global.css";
import "@fontsource/space-grotesk/300.css";
import "@fontsource/space-grotesk/400.css";
import "@fontsource/space-grotesk/500.css";
import "@fontsource/space-grotesk/600.css";
import "@fontsource/space-grotesk/700.css";
import "@fontsource/plus-jakarta-sans/500.css";
import "@fontsource/plus-jakarta-sans/600.css";
import "@fontsource/plus-jakarta-sans/700.css";
import "@fontsource/plus-jakarta-sans/800.css";
import "@fontsource/instrument-serif/400.css";
import "@fontsource/instrument-serif/400-italic.css";
---

<!doctype html>
<html lang="de" itemscope itemtype="https://schema.org/WebPage">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="robots" content={robots} />

        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonical} />
        <link rel="icon" type="image/svg+xml" href="/images/logo.svg" />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:locale" content="de_DE" />
        <meta property="og:site_name" content={siteName} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonical} />
        <meta property="og:image" content="https://st-automatisierung.de/images/hero_desktop_1769613342869.png" />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />

        <!-- Fonts (Local - GDPR Compliant) -->
        <!-- Space Grotesk imported via global.css or here directly -->

        <slot name="head" />

        {breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}

        <script type="application/ld+json" is:inline>
            {
                "@context": "https://schema.org",
                "@type": ["Organization", "LocalBusiness"],
                "name": "ST-Strategieberatung UG (haftungsbeschränkt)",
                "alternateName": "ST BERATUNG",
                "legalName": "ST-Strategieberatung UG (haftungsbeschränkt)",
                "description": "Unternehmensberatung für KI-Strategie & Prozess-Audits im deutschen Mittelstand. BAFA-förderfähig.",
                "url": "https://st-automatisierung.de",
                "logo": "https://st-automatisierung.de/images/logo.svg",
                "image": "https://st-automatisierung.de/images/hero_desktop_1769613342869.png",
                "priceRange": "€€",
                "currenciesAccepted": "EUR",
                "paymentAccepted": "Überweisung",
                "areaServed": {
                    "@type": "Country",
                    "name": "Deutschland"
                },
                "sameAs": [
                    "https://www.linkedin.com/in/safak-tepecik-b204b1133/",
                    "https://calendly.com/st-automatisierung-info/30min"
                ],
                "founder": {
                    "@type": "Person",
                    "name": "Safak Tepecik",
                    "jobTitle": "Geschäftsführer & KI-Systemarchitekt"
                },
                "knowsAbout": [
                    "KI-Strategie für den Mittelstand",
                    "Prozessautomatisierung",
                    "BAFA-Förderung für KMU",
                    "DSGVO-konforme KI-Einführung",
                    "EU AI Act Compliance",
                    "Rechnungsverarbeitung mit KI",
                    "Predictive Maintenance",
                    "Lead-Automatisierung",
                    "Dokumentenextraktion",
                    "ERP-Automatisierung"
                ],
                "address": {
                    "@type": "PostalAddress",
                    "streetAddress": "Heidestraße 2",
                    "addressLocality": "Schwerte",
                    "postalCode": "58239",
                    "addressCountry": "DE"
                },
                "contactPoint": {
                    "@type": "ContactPoint",
                    "telephone": "+49-1523-463-9525",
                    "contactType": "customer service",
