---
import { getCollection } from 'astro:content';

interface Props {
  currentSlug: string;
  currentCluster: string;
  limit?: number;
}

const { currentSlug, currentCluster, limit = 3 } = Astro.props;

const allPseoPages = await getCollection('pseo');

const relatedPages = allPseoPages
  .filter(page => {
    const hasFaq = !!page.data.faq;
    const hasRoi = !!page.data.roi_data;
    const isEnriched = hasFaq || hasRoi;
    const isDev = import.meta.env.DEV;
    const passGate = isEnriched || isDev;
    return passGate && page.data.cluster === currentCluster && page.slug !== currentSlug;
  })
  .sort(() => Math.random() - 0.5)
  .slice(0, limit);
---

{relatedPages.length > 0 && (
  <section class="py-16 border-t" style="border-color: var(--color-border); background: var(--color-bg-alt);">
    <div class="container max-w-4xl">
      <div class="flex items-center gap-3 mb-8">
        <svg class="w-6 h-6" style="color: var(--color-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
        <h2 class="text-2xl font-bold mb-0" style="color: var(--color-text-main);">Verwandte Strategien & Insights</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {relatedPages.map(page => (
          <a href={`/l/${page.slug}/`} class="group block p-5 rounded-xl border transition-all" style="border-color: var(--color-border); background: var(--color-surface);" onmouseover="this.style.borderColor='var(--color-accent)';this.style.boxShadow='var(--elev-3)'" onmouseout="this.style.borderColor='var(--color-border)';this.style.boxShadow='none'">
            <span class="inline-block px-2 py-1 text-xs rounded uppercase tracking-wider mb-3" style="background: var(--color-primary-light); color: var(--color-accent);">
              {page.data.cluster}
            </span>
            <h3 class="font-medium transition-colors line-clamp-3" style="color: var(--color-text-main);">
              {page.data.title}
            </h3>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
