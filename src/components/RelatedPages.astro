---
import { getCollection } from 'astro:content';

interface Props {
  currentSlug: string;
  currentCluster: string;
  limit?: number;
}

const { currentSlug, currentCluster, limit = 3 } = Astro.props;

// Hole alle pSEO Seiten
const allPseoPages = await getCollection('pseo');

// Logik für "Tiered Internal Linking" (Phase 07)
// 1. Priorisiere Seiten aus demselben Cluster
// 2. Schließe die aktuelle Seite aus
// 3. (In einer voll ausgebauten SSR-Version würde hier Traffic-Level aus einer DB gezogen. 
//    Da SSG, simulieren wir das Tiering durch Randomisierung zur Build-Zeit, 
//    um Pagerank gleichmäßig innerhalb des Clusters zu verteilen).
const relatedPages = allPseoPages
  .filter(page => {
    // Phase 08 pass: Only link to pages that actually exist (Enriched)
    const hasFaq = !!page.data.faq;
    const hasRoi = !!page.data.roi_data;
    const isEnriched = hasFaq || hasRoi;
    
    // In dev mode allow all, in prod only Enriched
    const isDev = import.meta.env.DEV;
    const passGate = isEnriched || isDev;

    return passGate && page.data.cluster === currentCluster && page.slug !== currentSlug;
  })
  .sort(() => Math.random() - 0.5) // Randomize for build-time variation
  .slice(0, limit);
---

{relatedPages.length > 0 && (
  <section class="py-16 border-t border-gray-800 bg-gray-900/30">
    <div class="container max-w-4xl">
      <div class="flex items-center gap-3 mb-8">
        <svg class="w-6 h-6 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
        <h2 class="text-2xl font-bold text-white mb-0">Verwandte Strategien & Insights</h2>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        {relatedPages.map(page => (
          <a href={`/l/${page.slug}`} class="group block p-5 rounded-xl border border-gray-700 bg-gray-800/50 hover:bg-gray-800 hover:border-blue-500/50 transition-all">
            <span class="inline-block px-2 py-1 bg-blue-500/10 text-blue-400 text-xs rounded uppercase tracking-wider mb-3">
              {page.data.cluster}
            </span>
            <h3 class="text-white font-medium group-hover:text-blue-400 transition-colors line-clamp-3">
              {page.data.title}
            </h3>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
