---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Unternehmensberatung für KI & Prozessoptimierung im Mittelstand | ST-Automatisierung";
const description =
    "Eingetragene Unternehmensberatung für den Mittelstand (25–250 MA). Wir eliminieren manuelle Engpässe durch rechtssichere Automatisierungsarchitekturen. Häufig förderfähig über BAFA-Programme.";
const canonical = new URL(
    Astro.url.pathname.replace(/\.html$/, ""),
    Astro.site,
);
---

<BaseLayout title={title} description={description} canonical={canonical}>
    <!-- HERO: Positionierung -->
    <section class="hero relative overflow-hidden">
        <!-- Responsive Tech Background (hidden via CSS, kept for OG fallback) -->
        <div class="hero-bg absolute inset-0 z-0 opacity-40">
            <picture>
                <source
                    media="(max-width: 768px)"
                    srcset="/images/hero_mobile_1769613427118.png"
                />
                <img
                    src="/images/hero_desktop_1769613342869.png"
                    alt="Abstract Tech Network Background"
                    class="w-full h-full object-cover"
                    width="1024"
                    height="1024"
                    loading="eager"
                />
            </picture>
        </div>

        <!-- Content: Split Layout -->
        <div class="container hero-content hero-split relative z-10">
            <div class="hero-text">
                <span class="section-label">Strategische Unternehmensberatung</span>
                <h1>Unternehmensberatung für <span class="keyword-highlight">KI-Strategie</span> & Prozess-Audits im Mittelstand</h1>
                <p class="hero-subhead">
                    Wir decken Ineffizienzen im deutschen Mittelstand auf. Als strategische Unternehmensberatung konzipieren wir rechtssichere Automatisierungsarchitekturen und Leitfäden, die Ihre manuellen Engpässe eliminieren. Wir begleiten Sie konzeptionell von der Analyse bis zum fertigen Strategieplan. Häufig durch Bundesmittel kofinanzierbar.
                </p>

                <div class="hero-cta">
                    <div>
                        <a
                            href="https://calendly.com/st-automatisierung-info/30min"
                            class="btn btn-primary">Initialgespräch vereinbaren</a
                        >
                        <p class="cta-microcopy">
                            Kostenfreies Erstgespräch. Inklusive Prüfung Ihrer BAFA-Förderfähigkeit.
                        </p>
                    </div>
                </div>

                <!-- Trust Indicators -->
                <div class="hero-trust">
                    <div class="trust-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        <span>BAFA-akkreditiert</span>
                    </div>
                    <div class="trust-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        <span>DSGVO & EU AI Act konform</span>
                    </div>
                    <div class="trust-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        <span>Herstellerunabhängig</span>
                    </div>
                </div>
            </div>

            <!-- Portrait -->
            <div class="hero-portrait">
                <div class="portrait-glow"></div>
                <img
                    src="/images/safak-tepecik.jpg"
                    alt="Safak Tepecik — Geschäftsführer & KI-Strategieberater"
                    width="400"
                    height="500"
                    class="portrait-img"
                    loading="eager"
                />
                <div class="portrait-badge">
                    <strong>Safak Tepecik</strong>
                    <span>Geschäftsführer & KI-Strategieberater</span>
                </div>
            </div>
        </div>
    </section>

    <main id="main-content">
        <!-- SECTION: Problemstellung (Mittelstand Fokus) -->
        <section class="section-block reveal">
          <div class="container">
            <span class="section-label">Ausgangslage</span>
            <h2>Die Realität: Warum der Mittelstand zögert</h2>
            <p>
                In vielen mittelständischen Unternehmen herrscht beim Thema
                Künstliche Intelligenz eine verständliche Zurückhaltung. Die
                mediale Berichterstattung wird dominiert von technologischen
                Superlativen, die an der betrieblichen Realität vorbeigehen.
                Gleichzeitig wächst der Druck durch Marktveränderungen und
                Fachkräftemangel.
            </p>
            <p>
                Entscheider in der Geschäftsführung und IT-Leitung stehen vor
                einem Dilemma: Einerseits droht der Anschlussverlust,
                andererseits sind die Risiken einer unkontrollierten Einführung
                – von Datenschutzverstößen bis hin zu Reputationsschäden – kaum
                kalkulierbar. Es fehlt nicht an Werkzeugen ("Tools"), sondern an
                einem verlässlichen Ordnungsrahmen für deren Einsatz.
            </p>

            <!-- Spannungsfeld: Clean CSS version replacing neon image -->
            <div class="spannungsfeld-visual" role="img" aria-label="Grafik: Spannungsfeld Mittelstand">
                <div class="sf-header">Das Spannungsfeld</div>
                <div class="sf-grid">
                    <div class="sf-pole">
                        <div class="sf-icon">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                        </div>
                        <span class="sf-label">Innovation</span>
                        <span class="sf-desc">Wettbewerbsfähigkeit sichern</span>
                    </div>
                    <div class="sf-pole">
                        <div class="sf-icon">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                        </div>
                        <span class="sf-label">Rechtssicherheit</span>
                        <span class="sf-desc">DSGVO & EU AI Act</span>
                    </div>
                    <div class="sf-pole">
                        <div class="sf-icon">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
                        </div>
                        <span class="sf-label">Stabilität</span>
                        <span class="sf-desc">Bestehende Prozesse schützen</span>
                    </div>
                </div>
                <p class="sf-bottom">Unsere Beratung navigiert dieses Spannungsfeld — strukturiert und herstellerunabhängig.</p>
            </div>

            <!-- Keep original img in DOM for SEO continuity, hidden -->
            <div class="hidden">
                <img
                    src="/images/spannungsfeld.png"
                    alt="Grafik: Spannungsfeld Mittelstand"
                    width="1024"
                    height="1024"
                    loading="lazy"
                />
            </div>
          </div>
        </section>

        <!-- SECTION: Engpässe (Pains) — Dark Contrast -->
        <section class="section-block section-dark reveal">
          <div class="container">
            <span class="section-label">Typische Engpässe</span>
            <h2>Welche Engpässe wir analytisch lösen</h2>
            <p>
                Technologische Strategie ist wertlos, wenn sie keine echten betriebswirtschaftlichen Schmerzen lindert. Als reine Unternehmensberatung fokussieren wir uns auf die konzeptionelle Beseitigung konkreter Wachstumsbremsen:
            </p>
            <div class="card-grid reveal-stagger">
                <article class="card">
                    <div class="card-icon card-icon-blue">
                        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <h3>Zähe Vertriebsprozesse</h3>
                    <p class="card-text">Untersuchung manueller Angebots- und Vertriebsstrukturen. Wir entwickeln Konzepte, wie der Angebotszyklus signifikant reduziert werden kann.</p>
                </article>

                <article class="card">
                    <div class="card-icon card-icon-blue">
                        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 012.012 1.244l.256.512a2.25 2.25 0 002.013 1.244h3.218a2.25 2.25 0 002.013-1.244l.256-.512a2.25 2.25 0 012.013-1.244h3.859m-19.5.338V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 00-2.15-1.588H6.911a2.25 2.25 0 00-2.15 1.588L2.35 13.177a2.25 2.25 0 00-.1.661z" />
                        </svg>
                    </div>
                    <h3>Struktureller Lead-Verlust</h3>
                    <p class="card-text">Analyse fehlender Follow-Up-Strukturen. Wir entwerfen konzeptionelle Architekturen für Systeme, die Leads lückenlos qualifizieren können.</p>
                </article>

                <article class="card">
                    <div class="card-icon card-icon-blue">
                        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                        </svg>
                    </div>
                    <h3>Fachkräftemangel</h3>
                    <p class="card-text">Identifikation von Routine-Tätigkeiten (Copy-Paste), die Mitarbeiter blockieren. Erstellung von Strategien, wie dieses Grundrauschen delegiert werden kann.</p>
                </article>
            </div>
          </div>
        </section>

        <!-- SECTION: Trust Anchors & Methodik -->
        <section class="section-block reveal">
          <div class="container">
            <span class="section-label">Unser Ansatz</span>
            <h2>Unser Ansatz: Konzepte statt Standardsoftware</h2>
            <p>
                Als strategische Unternehmensberatung konzentrieren wir uns auf das Prozess-Audit und die strategische Konzeption. Wir entwickeln fundierte Konzepte und Prozess-Audits, die Ihre manuellen Engpässe identifizieren und auflösen.
            </p>
            <p>
                Unsere Beratung setzt vor der Technik an: Bei der Identifikation ineffizienter Workflows, der Erstellung von Anforderungsprofilen und der Entwicklung rechtssicherer Leitfäden (unter Beachtung von DSGVO und EU AI Act).
            </p>
            <p>
                Wir liefern Ihnen den objektiven, herstellerunabhängigen Bauplan. Die spätere Umsetzung bleibt in Ihren Händen oder denen Ihrer bestehenden IT-Dienstleister.
            </p>

            <div class="principles-list">
                <div class="principle-item">
                    <div class="principle-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                    </div>
                    <div>
                        <strong>Rechtssicherheit:</strong> Berücksichtigung aktueller
                        Compliance-Anforderungen.
                    </div>
                </div>
                <div class="principle-item">
                    <div class="principle-icon principle-icon-amber">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    </div>
                    <div>
                        <strong>Bestandsschutz:</strong> Integration in gewachsene IT-Infrastrukturen
                        ohne "Abrissbirne".
                    </div>
                </div>
                <div class="principle-item">
                    <div class="principle-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    </div>
                    <div>
                        <strong>Mitarbeiterfokus:</strong> Technologie als Unterstützung,
                        nicht als Ersatz.
                    </div>
                </div>
            </div>
          </div>
        </section>

        <!-- SECTION: Qualifikationen / Trust Signals -->
        <section class="section-block section-alt reveal">
          <div class="container">
            <span class="section-label">Qualifikationen</span>
            <h2>Worauf Sie sich verlassen können</h2>
            <p>
                Strategieberatung im Mittelstand braucht verifizierbare Kompetenz — keine Marketing-Versprechen. Die folgenden Punkte bilden den objektiven Rahmen unserer Arbeit:
            </p>
            <div class="trust-grid reveal-stagger">
                <div class="trust-badge">
                    <div class="trust-badge-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
                    </div>
                    <strong>BAFA-Förderberater</strong>
                    <span>Akkreditierung zur KMU-Beratungsförderung des Bundes (BAFA-Zulassungsprogramm).</span>
                </div>
                <div class="trust-badge">
                    <div class="trust-badge-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
                    </div>
                    <strong>EU AI Act & DSGVO</strong>
                    <span>Alle Konzepte werden gegen aktuelle EU-Verordnungen und datenschutzrechtliche Anforderungen geprüft.</span>
                </div>
                <div class="trust-badge">
                    <div class="trust-badge-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
                    </div>
                    <strong>Herstellerunabhängig</strong>
                    <span>Keine Partner-Provisionen. Kein Tool-Bias. Die Empfehlung folgt ausschließlich Ihrem Bedarf.</span>
                </div>
                <div class="trust-badge">
                    <div class="trust-badge-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21"/></svg>
                    </div>
                    <strong>Eingetragene UG</strong>
                    <span>ST-Strategieberatung UG (haftungsbeschränkt), USt-ID DE356925446 — formaler Geschäftspartner für KMU.</span>
                </div>
            </div>
          </div>
        </section>

        <!-- SECTION: Realitätssignale & Förderung -->
        <section class="section-block reveal">
          <div class="container">
            <span class="section-label section-label-amber">Staatliche Förderung</span>
            <h2 class="h2-amber">Risiko halbiert. ROI verdoppelt. (Staatliche Förderung)</h2>
            <p>
                Unsere strategischen Beratungsleistungen zur Digitalisierung und Prozessoptimierung sind staatlich förderfähig. Über das offizielle Programm des Bundes („Förderung von Unternehmensberatungen für KMU" der BAFA) können kleine und mittlere Unternehmen einen massiven Teil der Beratungskosten zurückerhalten:
            </p>

            <!-- ROI Highlight Boxes -->
            <div class="stat-grid reveal-stagger">
                <div class="stat-card stat-card-green">
                    <div class="stat-label">Alte Bundesländer</div>
                    <div class="stat-value" data-count-to="50" data-count-suffix=" %">0 %</div>
                    <div class="stat-desc">Zuschuss (max. 1.750 €)</div>
                </div>
                <div class="stat-card stat-card-green">
                    <div class="stat-label">Neue Bundesländer</div>
                    <div class="stat-value" data-count-to="80" data-count-suffix=" %">0 %</div>
                    <div class="stat-desc">Zuschuss (max. 2.800 €)</div>
                </div>
                <div class="stat-card stat-card-amber">
                    <div class="stat-label">ROI der Beratung</div>
                    <div class="stat-value" data-count-to="17" data-count-suffix=":1">0:1</div>
                    <div class="stat-desc">im ersten Jahr</div>
                </div>
            </div>

            <p>
                Wir prüfen noch vor dem ersten Handschlag, ob Ihr Unternehmen das Raster erfüllt, und begleiten den strategischen Transformationsprozess von der Potenzialanalyse bis zur detaillierten Handlungsempfehlung. Der Staat trägt das Risiko der Strategiefindung – Sie behalten die volle Entscheidungskontrolle.
            </p>
          </div>
        </section>

        <!-- SECTION: Navigation / Weiche -->
        <section class="section-block reveal">
          <div class="container">
            <span class="section-label">Ihr nächster Schritt</span>
            <h2>Wählen Sie Ihren Einstieg</h2>
            <p>
                Je nach Reifegrad Ihres Unternehmens bieten wir zwei vertiefende
                Informationspfade an:
            </p>

            <div class="path-grid reveal-stagger">
                <!-- Pfad 1: Orientierung -->
                <article class="path-card">
                    <div class="path-number">1</div>
                    <h3>Grundlagen & Einordnung</h3>
                    <p>
                        Für Unternehmen, die verstehen wollen, was KI jenseits
                        des Hypes tatsächlich leisten kann und wo die
                        betriebswirtschaftlichen Grenzen liegen.
                    </p>
                    <a
                        href="/ki-im-unternehmen/"
                        class="btn btn-primary"
                        >Zur Analyse: KI im Unternehmen</a
                    >
                </article>

                <!-- Pfad 2: Umsetzung -->
                <article class="path-card path-card-amber">
                    <div class="path-number">2</div>
                    <h3>Strategie & Einführung</h3>
                    <p>
                        Für Unternehmen, die bereits entschieden haben, dass sie
                        handeln müssen, und nun nach einem sicheren
                        Vorgehensmodell suchen.
                    </p>
                    <a
                        href="/ki-einfuehrung-unternehmen/"
                        class="btn btn-primary"
                        >Zum Vorgehensmodell</a
                    >
                </article>
            </div>
          </div>
        </section>

        <!-- SECTION: Soft Conversion -->
        <section class="contact-section">
            <div class="container">
                <span class="section-label" style="background: linear-gradient(90deg, #FBBF24, #F59E0B); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Nächster Schritt</span>
                <h2>Klares Gespräch statt Vertrieb</h2>
                <p>
                    Wir glauben nicht an Standardpakete für komplexe
                    Organisationsfragen. Wenn Sie nach der Lektüre unserer Inhalte
                    Klärungsbedarf sehen, laden wir Sie zu einem ersten,
                    orientierenden Gespräch ein.
                </p>
                <div style="margin-top: 2rem;">
                    <a
                        href="https://calendly.com/st-automatisierung-info/30min"
                        class="btn btn-primary"
                        >Initialgespräch vereinbaren</a
                    >
                    <p class="cta-microcopy" style="color: rgba(255,255,255,0.7); margin-top: 1rem;">
                        Kostenfreies Erstgespräch. Inklusive Prüfung Ihrer BAFA-Förderfähigkeit.
                    </p>
                </div>
                <div class="contact-details">
                    <span>Sitz: Deutschland</span>
                    <a href="mailto:info@st-automatisierung.de"
                        >info@st-automatisierung.de</a
                    >
                </div>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    /* ===== Hero Split Layout ===== */
    .hero-split {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 3rem;
        align-items: center;
    }

    .hero-portrait {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .portrait-glow {
        position: absolute;
        width: 360px;
        height: 360px;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: conic-gradient(
            from 180deg,
            rgba(37, 99, 235, 0.25),
            rgba(217, 119, 6, 0.15),
            rgba(167, 139, 250, 0.2),
            rgba(37, 99, 235, 0.25)
        );
        filter: blur(60px);
        border-radius: 50%;
        z-index: -1;
    }

    .portrait-img {
        width: 300px;
        height: 375px;
        object-fit: cover;
        object-position: top;
        border-radius: var(--radius-lg);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        border: 2px solid rgba(255, 255, 255, 0.1);
    }

    .portrait-badge {
        margin-top: 1.25rem;
        text-align: center;
        max-width: 100%;
    }

    .portrait-badge strong {
        display: block;
        font-size: 1rem;
        color: #FFFFFF;
    }

    .portrait-badge span {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.5);
        display: block;
        white-space: normal;
    }

    /* Hero Trust */
    .hero-trust {
        display: flex;
        gap: 1.5rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        flex-wrap: wrap;
    }

    .trust-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8125rem;
