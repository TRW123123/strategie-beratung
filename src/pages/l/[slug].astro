---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import ContactForm from '../../components/ContactForm.astro';

export async function getStaticPaths() {
  const pseoEntries = await getCollection('pseo');
  
  // Phase 08: Bi-Modal Quality Gate
  // Only build pages that have at least one unique enrichment metric (FAQ OR ROI)
  // This physically enforces the 50% unique content rule against Thin Content.
  const isDev = import.meta.env.DEV; // Allow all in dev mode for content preview
  
  const verifiedEntries = pseoEntries.filter(entry => {
    const hasFaq = !!entry.data.faq;
    const hasRoi = !!entry.data.roi_data;
    const isEnriched = hasFaq || hasRoi;
    
    if (!isEnriched && !isDev) {
      console.warn(`[Quality Gate] PRUNED: ${entry.slug} (Missing FAQ or ROI)`);
      return false; // Skip build
    }
    return true; // Pass gate
  });

  return verifiedEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;

const canonicalData = `https://st-automatisierung.de/l/${entry.slug}/`;

// Cluster label mapping for breadcrumbs
const clusterLabels: Record<string, string> = {
  loesungen: 'Lösungen',
  probleme: 'Probleme',
  foerderung: 'Förderung',
  compliance: 'Compliance',
};

const breadcrumbs = [
  { name: 'Home', url: 'https://st-automatisierung.de/' },
  { name: clusterLabels[data.cluster] || data.cluster, url: 'https://st-automatisierung.de/loesungen-branchen/' },
  { name: data.title.length > 60 ? data.title.substring(0, 57) + '...' : data.title, url: canonicalData },
];

// --- Polymorphe DOM: Approach Steps ---
// Falls approach_steps im Frontmatter definiert sind, nutze diese.
// Sonst: Fallback auf cluster-spezifische Default-Steps.
const clusterDefaults: Record<string, { title: string; text: string }[]> = {
  loesungen: [
    { title: '1. Potenzial-Mapping', text: 'Systematische Identifikation der automatisierbaren Prozesse mit höchstem ROI in Ihrem Unternehmen.' },
    { title: '2. Architektur-Design', text: 'Entwicklung einer modularen, skalierbaren Lösungsarchitektur – passgenau für Ihre IT-Landschaft.' },
    { title: '3. Pilotierung & Skalierung', text: 'Kontrolliertes Rollout mit messbaren KPIs, bevor die Lösung unternehmensweit ausgerollt wird.' },
  ],
  probleme: [
    { title: '1. Diagnose des Engpasses', text: 'Forensische Analyse der Prozessbrüche, Datensilos und manuellen Workarounds in Ihrem Betrieb.' },
    { title: '2. System-Redesign', text: 'Entwicklung einer neuen Prozessarchitektur, die den identifizierten Engpass strukturell beseitigt.' },
    { title: '3. Nahtlose Integration', text: 'Einbettung der neuen Lösung in bestehende Systeme ohne Unterbrechung des operativen Betriebs.' },
  ],
  foerderung: [
    { title: '1. Förderfähigkeits-Check', text: 'Schnelle Prüfung, ob Ihr Unternehmen die KMU-Kriterien für BAFA- oder Landesförderung erfüllt.' },
    { title: '2. Antragsbegleitung', text: 'Formgerechte BAFA-Antragstellung – zwingend vor Maßnahmenbeginn – mit dokumentationssicherer Abwicklung.' },
    { title: '3. Strategieberatung mit Zuschuss', text: 'Durchführung der KI-Prozessberatung mit anschließender, garantierter Zuschuss-Abrechnung.' },
  ],
  compliance: [
    { title: '1. Regulatorische Bestandsaufnahme', text: 'Systematische Prüfung aller KI-Prozesse gegen aktuelle DSGVO-, AI-Act- und branchenspezifische Anforderungen.' },
    { title: '2. Risikobewertung & Gap-Analyse', text: 'Identifikation kritischer Compliance-Lücken und Erstellung eines priorisierten Maßnahmenplans.' },
    { title: '3. Umsetzungs-Framework', text: 'Implementierung technisch-organisatorischer Maßnahmen für rechtssichere KI-Nutzung in Ihrem Unternehmen.' },
  ],
};

const approachSteps = data.approach_steps || clusterDefaults[data.cluster] || clusterDefaults.loesungen;

// --- Polymorphe DOM: Content Format Selection ---
// Wählt die HTML-Struktur basierend auf content_format oder cluster.
const contentFormat = data.content_format || (data.cluster === 'compliance' ? 'checklist' : data.cluster === 'foerderung' ? 'steps' : 'prose');
---

<BaseLayout
  title={data.title}
  description={data.description}
  canonical={canonicalData}
  breadcrumbs={breadcrumbs}
>
  <!-- JSON-LD Schema Injection (P0) -->
  <ArticleSchema
    slot="head"
    title={data.title}
    description={data.description}
    keyword={data.keyword}
    slug={entry.slug}
    cluster={data.cluster}
    faq={data.faq}
  />
  <!-- GEO: Citation Meta Tags for AI Crawlers -->
  <meta slot="head" name="citation_title" content={data.title} />
  <meta slot="head" name="citation_author" content="Şafak Tepecik" />
  <meta slot="head" name="citation_publication_date" content="2026-01-15" />
  <meta slot="head" name="citation_publisher" content="ST BERATUNG" />
  <meta slot="head" name="citation_language" content="de" />
  <meta slot="head" itemprop="description" content={data.description} />

  <main id="main-content">
    <article itemscope itemtype="https://schema.org/Article">

      <section class="pseo-hero">
        <div class="container pseo-hero-content">
          <!-- Badges -->
          <div class="pseo-badges">
              <span class={`pseo-badge pseo-cluster-${data.cluster}`}>
                {clusterLabels[data.cluster] || data.cluster}
              </span>
              {data.bafa_badge && (
                <span class="pseo-badge pseo-badge-bafa">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  BAFA-Förderung: bis zu 80% Zuschuss
                </span>
              )}
          </div>

          <h1 class="pseo-title" itemprop="headline">
              {data.title}
          </h1>

          <p class="pseo-intro">
            {data.description}
          </p>

          <!-- Author Byline (E-E-A-T) -->
          <div class="pseo-meta">
            <div class="pseo-author" itemprop="author" itemscope itemtype="https://schema.org/Person">
              <div class="pseo-author-avatar">ST</div>
              <div class="pseo-author-info">
                <strong itemprop="name">Şafak Tepecik</strong>
                <span>KI-Systemarchitekt & Unternehmensberater</span>
              </div>
            </div>
            <span class="pseo-meta-divider"></span>
            <span class="pseo-meta-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
              ~ 6 Min. Lesezeit
            </span>
          </div>
        </div>
      </section>

      <section class="pseo-content">
        <div class="container">
          <!-- Main Content (Polymorphe Prose) -->
          <div class="pseo-body prose" itemprop="articleBody">
            <Content />
          </div>

          <!-- ROI Data Point (conditional) -->
          {data.roi_data && (
            <div class="mb-12 p-6 bg-gradient-to-r from-blue-900/30 to-transparent rounded-xl border border-blue-500/20">
              <div class="text-sm text-blue-400 uppercase tracking-widest mb-1">Kennzahl</div>
              <div class="text-3xl font-bold text-white">{data.roi_data.value}</div>
              <div class="text-gray-400 mt-1">{data.roi_data.metric}</div>
              {data.roi_data.source && <div class="text-xs text-gray-500 mt-2">Quelle: {data.roi_data.source}</div>}
            </div>
          )}

          {/* --- Savings Range (conditional) --- */}
          {data.savings_range && (
            <div class="mb-12 p-6 bg-green-900/20 rounded-xl border border-green-500/20">
              <div class="text-sm text-green-400 uppercase tracking-widest mb-1">Einsparpotential</div>
              <div class="text-3xl font-bold text-white">
                {data.savings_range.min.toLocaleString('de-DE')} – {data.savings_range.max.toLocaleString('de-DE')}
                {data.savings_range.unit === 'euro_per_year' && ' €/Jahr'}
                {data.savings_range.unit === 'hours_per_week' && ' Std./Woche'}
                {data.savings_range.unit === 'percent' && ' %'}
              </div>
            </div>
          )}

          {/* --- Community Context / UGC Injection (Phase 06) --- */}
          {data.community_context && (
            <div class="mb-12 p-6 bg-gray-800/80 rounded-xl border-l-4 border-l-purple-500 border-t border-r border-b border-gray-700 relative overflow-hidden">
              <div class="absolute top-0 right-0 p-4 opacity-10">
                <svg viewBox="0 0 24 24" class="w-16 h-16 fill-current text-white"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/></svg>
              </div>
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs uppercase tracking-widest text-purple-400 font-semibold">Markt-Insight</span>
                <span class="flex items-center gap-1 text-xs text-gray-500 bg-gray-900 px-2 py-0.5 rounded-full">
                  Signal via {data.community_context.platform}
                </span>
              </div>
              <blockquote class="text-gray-300 italic mb-0 relative z-10">
                "{data.community_context.insight}"
              </blockquote>
            </div>
          )}

          <div class="pseo-cta-row">
              <a href="#kontaktformular" class="btn btn-primary">
                  Kostenlose Potenzialanalyse anfragen
              </a>
              <a href="/ki-im-unternehmen/" class="btn btn-secondary">
                  Mehr über unsere Methodik
              </a>
          </div>
        </div>
      </section>

      <!-- ===== POLYMORPHE "Unser Ansatz" SECTION ===== -->
      <!-- DOM-Struktur variiert nach content_format, um Template-Fingerprint zu verschleiern -->
      <section class="py-20 bg-gray-900/50 border-t border-gray-800">
          <div class="container">
              <h2 class="text-3xl font-bold mb-12">Unser Ansatz für {data.keyword}</h2>

              {/* --- Format: Grid Cards (default für 'loesungen') --- */}
              {contentFormat === 'prose' && (
                <div class="grid md:grid-cols-3 gap-8">
                    {approachSteps.map((step) => (
                        <div class="p-6 bg-gray-800/50 rounded-xl border border-gray-700">
                            <h3 class="text-xl font-semibold mb-3">{step.title}</h3>
                            <p class="text-gray-400">{step.text}</p>
                        </div>
                    ))}
                </div>
              )}

              {/* --- Format: Definition List (für 'probleme') --- */}
              {contentFormat === 'checklist' && (
                <dl class="space-y-6 max-w-3xl">
                    {approachSteps.map((step) => (
                        <div class="border-l-2 border-blue-500 pl-6">
                            <dt class="text-lg font-semibold text-white">{step.title}</dt>
                            <dd class="text-gray-400 mt-1">{step.text}</dd>
                        </div>
                    ))}
                </dl>
              )}

              {/* --- Format: Numbered Steps (für 'foerderung') --- */}
              {contentFormat === 'steps' && (
                <ol class="space-y-8 max-w-3xl list-none p-0">
                    {approachSteps.map((step, i) => (
                        <li class="flex gap-4 items-start">
                            <span class="flex-shrink-0 w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-lg">{i + 1}</span>
                            <div>
                                <h3 class="text-lg font-semibold text-white">{step.title}</h3>
                                <p class="text-gray-400 mt-1">{step.text}</p>
                            </div>
                        </li>
                    ))}
                </ol>
              )}

              {/* --- Format: Comparison Table (für 'compliance') --- */}
              {contentFormat === 'comparison' && (
                <div class="overflow-x-auto">
                  <table class="w-full max-w-3xl text-left border-collapse">
                    <thead>
                      <tr class="border-b border-gray-700">
                        <th class="pb-3 text-gray-400 font-medium">Phase</th>
                        <th class="pb-3 text-gray-400 font-medium">Beschreibung</th>
                      </tr>
                    </thead>
                    <tbody>
                      {approachSteps.map((step) => (
                        <tr class="border-b border-gray-800">
                          <td class="py-4 pr-6 font-semibold text-white whitespace-nowrap">{step.title}</td>
                          <td class="py-4 text-gray-400">{step.text}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
          </div>
      </section>

      <!-- ===== FAQ SECTION (conditional, für FAQPage Schema) ===== -->
      {data.faq && data.faq.length > 0 && (
        <section class="py-16 border-t border-gray-800">
          <div class="container max-w-3xl">
            <h2 class="text-2xl font-bold mb-8">Häufige Fragen</h2>
            <div class="space-y-4">
              {data.faq.map((item) => (
                <FaqAccordion faqItem={item} />
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- ===== SOURCES (conditional) ===== -->
      {data.sources && data.sources.length > 0 && (
        <aside class="py-8 border-t border-gray-800">
          <div class="container max-w-3xl">
            <h3 class="text-sm uppercase tracking-widest text-gray-500 mb-4">Quellen</h3>
            <ul class="text-sm text-gray-500 space-y-1">
              {data.sources.map((src) => (
                <li>
                  {src.url ? (
                    <a href={src.url} target="_blank" rel="noopener noreferrer" class="hover:text-gray-300 transition-colors">{src.name}</a>
                  ) : (
                    <span>{src.name}</span>
                  )}
                </li>
              ))}
            </ul>
          </div>
        </aside>
      )}

      <!-- ===== CONTACT FORM ===== -->
      <section class="py-20 border-t border-gray-800">
        <div class="container max-w-2xl">
          <ContactForm sourcePage={`/l/${entry.slug}/`} />
        </div>
      </section>

      {/* --- INTERNAL LINKING (Phase 07) --- */}
      <RelatedPages currentSlug={entry.slug} currentCluster={data.cluster} limit={3} />

    </article>
  </main>
</BaseLayout>
