---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPseo = await getCollection('pseo');

// Group by cluster
const clusters = {
  loesungen: allPseo.filter(p => p.data.cluster === 'loesungen'),
  probleme: allPseo.filter(p => p.data.cluster === 'probleme'),
  foerderung: allPseo.filter(p => p.data.cluster === 'foerderung'),
  compliance: allPseo.filter(p => p.data.cluster === 'compliance'),
};

const clusterTitles = {
  loesungen: "Branchen-Lösungen & Prozesse",
  probleme: "Pain Points & Software-Limitierungen",
  foerderung: "Fördermittel & Zuschüsse",
  compliance: "Compliance, DSGVO & AI Act"
};

const clusterIcons: Record<string, string> = {
  loesungen: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z",
  probleme: "M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z M12 15.75h.007v.008H12v-.008z",
  foerderung: "M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z",
  compliance: "M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
};
---

<BaseLayout 
  title="KI-Lösungen und Branchen für den Mittelstand | ST BERATUNG"
  description="Übersicht aller KI-Automatisierungslösungen, Fördermöglichkeiten und Compliance-Richtlinien für den deutschen Mittelstand."
  canonical="https://st-automatisierung.de/loesungen-branchen/"
>
  <main id="main-content">
    <section class="loesungen-hero">
      <div class="container loesungen-hero-content">
        <span class="section-label">Ressourcen & Use Cases</span>
        <h1>Branchen & Lösungen</h1>
        <p class="loesungen-hero-subhead">
          Von der automatisierten Rechnungsverarbeitung bis zur rechtssicheren KI-Richtlinie: Finden Sie exakt den Prozess, der in Ihrem Unternehmen aktuell am meisten Zeit und Geld kostet.
        </p>
        <div class="loesungen-stats">
          <div class="loesungen-stat">
            <span class="loesungen-stat-value" data-count-to={allPseo.length}>0</span>
            <span class="loesungen-stat-label">Strategie-Guides</span>
          </div>
          <div class="loesungen-stat-divider"></div>
          <div class="loesungen-stat">
            <span class="loesungen-stat-value" data-count-to="4">0</span>
            <span class="loesungen-stat-label">Themen-Cluster</span>
          </div>
          <div class="loesungen-stat-divider"></div>
          <div class="loesungen-stat">
            <span class="loesungen-stat-value"><span style="color: var(--color-warm);">BAFA</span></span>
            <span class="loesungen-stat-label">förderfähig</span>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20">
      <div class="container">
        <div class="space-y-16">
          {Object.entries(clusters).map(([key, rawItems]) => {
            const items = rawItems.sort((a, b) => a.data.title.localeCompare(b.data.title));
            if (items.length === 0) return null;

            return (
              <div class={`cluster-section cluster-${key}`}>
                <div class="cluster-header">
                  <span class={`cluster-icon cluster-icon-${key}`}>
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d={(clusterIcons as any)[key] || clusterIcons.loesungen} />
                    </svg>
                  </span>
                  <h2 class="cluster-title">{(clusterTitles as any)[key]}</h2>
                  <span class="cluster-count">{items.length}</span>
                </div>
                <div class="cluster-grid">
                  {items.map(item => (
                    <a
                      href={`/l/${item.slug}/`}
                      class="cluster-card"
                    >
                      <h3 class="cluster-card-title">
                        {item.data.title}
                      </h3>
                      <p class="cluster-card-desc">
                        {item.data.intent}
                      </p>
                      <span class="cluster-card-arrow">→</span>
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <section class="contact-section">
      <div class="container">
        <span class="section-label" style="background: linear-gradient(90deg, #FBBF24, #F59E0B); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Ihr Prozess fehlt?</span>
        <h2>Ihr Problem ist nicht dabei?</h2>
        <p>
          Jeder Mittelständler hat historisch gewachsene, individuelle Prozesse. Lassen Sie uns in einer kostenlosen Potenzialanalyse herausfinden, wo Ihre versteckten Rendite-Killer liegen.
        </p>
        <div style="margin-top: 2rem;">
          <a href="mailto:info@st-automatisierung.de" class="btn btn-primary">
            Prozess-Audit anfragen
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .loesungen-hero {
    position: relative;
    padding: 6rem 0 4rem;
    background: linear-gradient(160deg, #0B1120 0%, #111B2E 50%, #0F1A2E 100%);
    overflow: hidden;
  }

  .loesungen-hero::before {
    content: "";
    position: absolute;
    top: -30%;
    right: -15%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.1) 0%, transparent 60%);
    pointer-events: none;
  }

  .loesungen-hero::after {
    content: "";
    position: absolute;
    bottom: -20%;
    left: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(217, 119, 6, 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .loesungen-hero-content {
    position: relative;
    z-index: 10;
  }

  .loesungen-hero h1 {
    color: #FFFFFF;
    max-width: 720px;
    margin-bottom: 1.5rem;
  }

  .loesungen-hero h1::after {
    background: linear-gradient(90deg, var(--color-warm), transparent);
  }

  .loesungen-hero-subhead {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 620px;
    line-height: 1.75;
    margin-bottom: 2.5rem;
  }

  .loesungen-hero .section-label {
    color: var(--color-warm);
    -webkit-text-fill-color: unset;
    background: none;
    font-weight: 700;
  }

  .loesungen-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    flex-wrap: wrap;
  }

  .loesungen-stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .loesungen-stat-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: #FFFFFF;
    line-height: 1;
  }

  .loesungen-stat-label {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .loesungen-stat-divider {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.15);
  }

  @media (max-width: 480px) {
    .loesungen-hero h1 {
      font-size: 1.75rem;
    }

    .loesungen-stats {
      gap: 1rem;
    }

    .loesungen-stat-divider {
      display: none;
    }

    .loesungen-stat-value {
      font-size: 1.5rem;
    }
  }

  /* ===== Cluster Differentiation ===== */
  .cluster-section {
    position: relative;
    padding-left: 1.5rem;
  }

  .cluster-section::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.75rem;
    bottom: 0.5rem;
    width: 3px;
    border-radius: 3px;
    background: var(--cluster-color, var(--color-accent));
  }

  .cluster-loesungen { --cluster-color: #2563EB; --cluster-light: #DBEAFE; }
  .cluster-probleme { --cluster-color: #DC2626; --cluster-light: #FEE2E2; }
  .cluster-foerderung { --cluster-color: #059669; --cluster-light: #D1FAE5; }
  .cluster-compliance { --cluster-color: #D97706; --cluster-light: #FEF3C7; }

  .cluster-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .cluster-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cluster-light);
    color: var(--cluster-color);
    flex-shrink: 0;
  }

  .cluster-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-main);
    margin: 0;
    padding: 0;
    border: none;
  }

  .cluster-title::after {
    display: none;
  }

  .cluster-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 24px;
    padding: 0 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    font-family: var(--font-heading);
    color: var(--cluster-color);
    background: var(--cluster-light);
    border-radius: 999px;
  }

  .cluster-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .cluster-card {
    position: relative;
    display: block;
    padding: 1.25rem 1.25rem 1.25rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.3s var(--spring-smooth);
    overflow: hidden;
  }

  .cluster-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--cluster-color);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--spring-smooth);
  }

  .cluster-card:hover {
    transform: translateY(-3px);
    border-color: var(--cluster-color);
    box-shadow: 0 10px 24px -8px color-mix(in srgb, var(--cluster-color) 25%, transparent);
    text-decoration: none;
  }

  .cluster-card:hover::before {
    transform: scaleX(1);
  }

  .cluster-card-title {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text-main) !important;
    margin: 0 0 0.5rem;
    padding: 0;
    border: none;
    line-height: 1.4;
  }

  .cluster-card-title::after {
    display: none;
  }

  .cluster-card-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cluster-card-arrow {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    color: var(--cluster-color);
    opacity: 0;
    transform: translateX(-6px);
    transition: all 0.3s var(--spring-smooth);
  }

  .cluster-card:hover .cluster-card-arrow {
    opacity: 1;
    transform: translateX(0);
  }
</style>
