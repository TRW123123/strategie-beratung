---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPseo = await getCollection('pseo');

// Group by cluster
const clusters = {
  loesungen: allPseo.filter(p => p.data.cluster === 'loesungen'),
  probleme: allPseo.filter(p => p.data.cluster === 'probleme'),
  foerderung: allPseo.filter(p => p.data.cluster === 'foerderung'),
  compliance: allPseo.filter(p => p.data.cluster === 'compliance'),
};

const clusterTitles = {
  loesungen: "Branchen-Lösungen & Prozesse",
  probleme: "Pain Points & Software-Limitierungen",
  foerderung: "Fördermittel & Zuschüsse",
  compliance: "Compliance, DSGVO & AI Act"
};

const clusterIcons: Record<string, string> = {
  loesungen: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z",
  probleme: "M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z M12 15.75h.007v.008H12v-.008z",
  foerderung: "M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z",
  compliance: "M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
};
---

<BaseLayout 
  title="KI-Lösungen und Branchen für den Mittelstand | ST BERATUNG"
  description="Übersicht aller KI-Automatisierungslösungen, Fördermöglichkeiten und Compliance-Richtlinien für den deutschen Mittelstand."
  canonical="https://st-automatisierung.de/loesungen-branchen/"
>
  <main id="main-content">
    <section class="loesungen-hero">
      <div class="container loesungen-hero-content">
        <span class="section-label">Ressourcen & Use Cases</span>
        <h1>Branchen & Lösungen</h1>
        <p class="loesungen-hero-subhead">
          Von der automatisierten Rechnungsverarbeitung bis zur rechtssicheren KI-Richtlinie: Finden Sie exakt den Prozess, der in Ihrem Unternehmen aktuell am meisten Zeit und Geld kostet.
        </p>
        <div class="loesungen-stats">
          <div class="loesungen-stat">
            <span class="loesungen-stat-value">{allPseo.length}</span>
            <span class="loesungen-stat-label">Strategie-Guides</span>
          </div>
          <div class="loesungen-stat-divider"></div>
          <div class="loesungen-stat">
            <span class="loesungen-stat-value">4</span>
            <span class="loesungen-stat-label">Themen-Cluster</span>
          </div>
          <div class="loesungen-stat-divider"></div>
          <div class="loesungen-stat">
            <span class="loesungen-stat-value"><span style="color: var(--color-warm);">BAFA</span></span>
            <span class="loesungen-stat-label">förderfähig</span>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20">
      <div class="container">
        <div class="space-y-16">
          {Object.entries(clusters).map(([key, rawItems]) => {
            const items = rawItems.sort((a, b) => a.data.title.localeCompare(b.data.title));
            if (items.length === 0) return null;
            
            return (
              <div>
                <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
                  <span class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d={(clusterIcons as any)[key] || clusterIcons.loesungen} />
                    </svg>
                  </span>
                  {(clusterTitles as any)[key]}
                </h2>
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
                  {items.map(item => (
                    <a 
                      href={`/l/${item.slug}/`} 
                      class="block p-4 rounded-lg bg-gray-800/30 border border-gray-800 hover:border-gray-600 hover:bg-gray-800/80 transition-colors group"
                    >
                      <h3 class="font-medium text-gray-200 group-hover:text-white mb-2 leading-snug">
                        {item.data.title}
                      </h3>
                      <p class="text-sm text-gray-500 line-clamp-2">
                        {item.data.intent}
                      </p>
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <section class="contact-section">
      <div class="container">
        <span class="section-label" style="background: linear-gradient(90deg, #FBBF24, #F59E0B); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Ihr Prozess fehlt?</span>
        <h2>Ihr Problem ist nicht dabei?</h2>
        <p>
          Jeder Mittelständler hat historisch gewachsene, individuelle Prozesse. Lassen Sie uns in einer kostenlosen Potenzialanalyse herausfinden, wo Ihre versteckten Rendite-Killer liegen.
        </p>
        <div style="margin-top: 2rem;">
          <a href="mailto:info@st-automatisierung.de" class="btn btn-primary">
            Prozess-Audit anfragen
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .loesungen-hero {
    position: relative;
    padding: 6rem 0 4rem;
    background: linear-gradient(160deg, #0B1120 0%, #111B2E 50%, #0F1A2E 100%);
    overflow: hidden;
  }

  .loesungen-hero::before {
    content: "";
    position: absolute;
    top: -30%;
    right: -15%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.1) 0%, transparent 60%);
    pointer-events: none;
  }

  .loesungen-hero::after {
    content: "";
    position: absolute;
    bottom: -20%;
    left: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(217, 119, 6, 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .loesungen-hero-content {
    position: relative;
    z-index: 10;
  }

  .loesungen-hero h1 {
    color: #FFFFFF;
    max-width: 720px;
    margin-bottom: 1.5rem;
  }

  .loesungen-hero h1::after {
    background: linear-gradient(90deg, var(--color-warm), transparent);
  }

  .loesungen-hero-subhead {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 620px;
    line-height: 1.75;
    margin-bottom: 2.5rem;
  }

  .loesungen-hero .section-label {
    color: var(--color-warm);
    -webkit-text-fill-color: unset;
    background: none;
    font-weight: 700;
  }

  .loesungen-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    flex-wrap: wrap;
  }

  .loesungen-stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .loesungen-stat-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: #FFFFFF;
    line-height: 1;
  }

  .loesungen-stat-label {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .loesungen-stat-divider {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.15);
  }

  @media (max-width: 480px) {
    .loesungen-hero h1 {
      font-size: 1.75rem;
    }

    .loesungen-stats {
      gap: 1rem;
    }

    .loesungen-stat-divider {
      display: none;
    }

    .loesungen-stat-value {
      font-size: 1.5rem;
    }
  }
</style>
